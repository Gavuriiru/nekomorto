# Base local env.
# Consulte o README (secao 7) para defaults, ranges e condicoes completas.

# Runtime e rede
# Use development localmente; deploys publicados usam production.
NODE_ENV=development
# Porta HTTP da app.
PORT=8080
# String de conexao PostgreSQL obrigatoria.
DATABASE_URL=
# Tentativas totais para aguardar a DB ficar disponivel no boot/migrate.
DB_STARTUP_MAX_ATTEMPTS=10
# Espera entre tentativas de bootstrap/migrate da DB em ms.
DB_STARTUP_RETRY_DELAY_MS=3000
# Timeout padrao das transacoes Prisma em ms.
PRISMA_TX_TIMEOUT_MS=30000
# Espera maxima da fila de transacoes Prisma em ms.
PRISMA_TX_MAX_WAIT_MS=5000
# Bloqueia mutacoes POST/PUT/PATCH/DELETE quando habilitado.
MAINTENANCE_MODE=false
# Nome da tabela de sessoes no Postgres.
SESSION_TABLE=user_sessions
# Base URL opcional para smoke/health checks em cutover.
STAGING_API_BASE=
# CSV de origens publicas absolutas permitidas para CORS/CSRF.
APP_ORIGIN=https://example.com,https://www.example.com
# Override opcional da base da API no frontend.
# Use URL absoluta ou deixe vazio para same-origin.
VITE_API_BASE=
# Ativa assets PWA no Vite dev somente com true literal.
VITE_PWA_DEV_ENABLED=false

# Auth, sessao e bootstrap
# Client ID do OAuth do Discord.
DISCORD_CLIENT_ID=
# Client secret do OAuth do Discord.
DISCORD_CLIENT_SECRET=
# Use auto ou uma URL absoluta apontando para /login.
DISCORD_REDIRECT_URI=auto
# Secret principal de sessao; use um valor longo e aleatorio fora do dev local.
SESSION_SECRET=
# Lista opcional de rotacao de secrets, mais novo primeiro.
SESSION_SECRETS=
# CSV de IDs de usuario do Discord para owners iniciais.
OWNER_IDS=
# Token one-shot para POST /api/bootstrap-owner quando OWNER_IDS estiver vazio.
BOOTSTRAP_TOKEN=

# Frontend e feature flags
# Habilita autosave do dashboard por padrao.
VITE_DASHBOARD_AUTOSAVE_ENABLED=true
# Debounce do autosave em ms.
VITE_DASHBOARD_AUTOSAVE_DEBOUNCE_MS=1200
# Quantidade maxima de retries do autosave.
VITE_DASHBOARD_AUTOSAVE_RETRY_MAX=2
# Base do backoff de retry do autosave em ms.
VITE_DASHBOARD_AUTOSAVE_RETRY_BASE_MS=1500
# Ativa o backend do RBAC v2.
RBAC_V2_ENABLED=false
# Mantem compatibilidade com o atalho legado * no RBAC v2.
RBAC_V2_ACCEPT_LEGACY_STAR=true
# Ativa o frontend para grants do RBAC v2.
VITE_RBAC_V2_ENABLED=false

# Analytics e comportamento operacional
# Salt opcional para hash de IP em analytics.
ANALYTICS_IP_SALT=
# Retencao dos eventos brutos de analytics em dias.
ANALYTICS_RETENTION_DAYS=90
# Retencao dos agregados de analytics em dias.
ANALYTICS_AGG_RETENTION_DAYS=365
# Reorganiza uploads automaticamente no startup quando habilitado.
AUTO_UPLOAD_REORGANIZE_ON_STARTUP=false
# Tamanho alvo do JPEG publico de OG em KB.
OG_PUBLIC_TARGET_KB=350
# CSV da escada de qualidades JPEG de OG.
OG_PUBLIC_JPEG_QUALITIES=84,80,76,72

# Uploads/storage
# Qualidade AVIF global das variantes geradas para uploads.
# Valores maiores aumentam fidelidade e bytes; uploads existentes exigem regeneracao/backfill.
UPLOAD_VARIANT_AVIF_QUALITY=90
# Provider ativo: local por padrao, s3 para AWS S3/R2 e similares.
UPLOAD_STORAGE_DRIVER=local
# Mantenha proxy para preservar o contrato /uploads/...
UPLOAD_STORAGE_DELIVERY=proxy
# Bucket do provider S3-compatible.
UPLOAD_STORAGE_BUCKET=
# Regiao do bucket; em R2 use auto.
UPLOAD_STORAGE_REGION=
# Endpoint customizado do provider.
UPLOAD_STORAGE_ENDPOINT=
# Access key do provider.
UPLOAD_STORAGE_ACCESS_KEY_ID=
# Secret key do provider.
UPLOAD_STORAGE_SECRET_ACCESS_KEY=
# Prefixo opcional das object keys sem / inicial/final.
UPLOAD_STORAGE_PREFIX=
# Use true somente se o provider exigir path-style.
UPLOAD_STORAGE_S3_FORCE_PATH_STYLE=false
# URL publica reservada para futuros fluxos de entrega direta.
UPLOAD_STORAGE_PUBLIC_BASE_URL=

# Seguranca, MFA, exports, metrics e alerts
# Keyring JSON para criptografia em repouso.
# Exemplo: {"activeKeyId":"key-2026-01","keys":{"key-2026-01":"<base64>","key-2025-12":"<base64>"}}
DATA_ENCRYPTION_KEYS_JSON=
# Pepper adicional para recovery codes de MFA.
SECURITY_RECOVERY_CODE_PEPPER=
# Nome exibido pelos apps autenticadores no TOTP.
MFA_ISSUER=Nekomata
# URL publica opcional do icone TOTP.
TOTP_ICON_URL=
# TTL da tentativa de enrollment MFA em ms.
MFA_ENROLLMENT_TTL_MS=600000
# Diretorio temporario dos exports administrativos.
ADMIN_EXPORTS_DIR=backups/admin-exports
# TTL dos exports administrativos em horas.
ADMIN_EXPORT_TTL_HOURS=24
# Habilita metrics operacionais.
METRICS_ENABLED=false
# Token exigido quando METRICS_ENABLED=true.
METRICS_TOKEN=
# Liga o webhook de alerts operacionais.
OPS_ALERTS_WEBHOOK_ENABLED=false
# Provider do webhook; hoje o suporte oficial e discord.
OPS_ALERTS_WEBHOOK_PROVIDER=discord
# URL do webhook operacional.
OPS_ALERTS_WEBHOOK_URL=
# Timeout do webhook em ms.
OPS_ALERTS_WEBHOOK_TIMEOUT_MS=5000
# Intervalo minimo entre envios do webhook em ms.
OPS_ALERTS_WEBHOOK_INTERVAL_MS=60000
# Latencia de banco que passa a gerar warning em ms.
OPS_ALERTS_DB_LATENCY_WARNING_MS=1000
