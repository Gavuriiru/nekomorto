# Producao com Docker Compose.
# Consulte o README (secao 7) para defaults, ranges e condicoes completas.

# Runtime e deploy
# Use production em ambientes publicados.
NODE_ENV=production
# Porta HTTP interna da app.
PORT=8080
# Bloqueia mutacoes da API durante manutencao.
MAINTENANCE_MODE=false
# Repositorio da imagem Docker da app.
APP_IMAGE_REPO=ghcr.io/gavuriiru/nekomorto
# Tag da imagem Docker da app.
APP_IMAGE_TAG=latest

# Postgres do compose
# Nome do banco inicial.
POSTGRES_DB=nekomorto
# Usuario do container Postgres.
POSTGRES_USER=nekomorto_app
# Senha obrigatoria do container Postgres.
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
# String de conexao da app para o host interno postgres.
DATABASE_URL=postgresql://nekomorto_app:CHANGE_ME_STRONG_PASSWORD@postgres:5432/nekomorto

# Auth, sessao e bootstrap
# Secret principal de sessao.
SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SECRET
# Lista opcional de rotacao de secrets, mais novo primeiro.
SESSION_SECRETS=
# Nome da tabela de sessoes.
SESSION_TABLE=user_sessions
# CSV de origens publicas permitidas.
APP_ORIGIN=https://nekomata.moe,https://www.nekomata.moe
# Origens extras para painel/admin.
ADMIN_ORIGINS=https://nekomata.moe
# Client ID do OAuth do Discord.
DISCORD_CLIENT_ID=
# Client secret do OAuth do Discord.
DISCORD_CLIENT_SECRET=
# Use auto ou uma URL absoluta apontando para /login.
DISCORD_REDIRECT_URI=auto
# Em producao same-origin, deixe VITE_API_BASE vazio.
# VITE_API_BASE=
# CSV de IDs de owners iniciais.
OWNER_IDS=
# Token one-shot para bootstrap quando OWNER_IDS estiver vazio.
BOOTSTRAP_TOKEN=

# Analytics e comportamento operacional
# Salt opcional para hash de IP em analytics.
ANALYTICS_IP_SALT=
# Retencao dos eventos brutos em dias.
ANALYTICS_RETENTION_DAYS=90
# Retencao dos agregados em dias.
ANALYTICS_AGG_RETENTION_DAYS=365
# Reorganiza uploads automaticamente no startup quando habilitado.
AUTO_UPLOAD_REORGANIZE_ON_STARTUP=false

# Frontend e feature flags
# Ativa o backend do RBAC v2.
RBAC_V2_ENABLED=false
# Mantem compatibilidade com o atalho legado * no RBAC v2.
RBAC_V2_ACCEPT_LEGACY_STAR=true

# Uploads/storage
# Qualidade AVIF global das variantes geradas para uploads.
# Valores maiores aumentam fidelidade e bytes; uploads existentes exigem regeneracao/backfill.
UPLOAD_VARIANT_AVIF_QUALITY=90

# Seguranca, MFA, exports, metrics e alerts
# Keyring JSON para criptografia em repouso.
DATA_ENCRYPTION_KEYS_JSON=
# Pepper adicional para recovery codes de MFA.
SECURITY_RECOVERY_CODE_PEPPER=
# Nome exibido pelos apps autenticadores no TOTP.
MFA_ISSUER=Nekomata
# URL publica opcional do icone TOTP.
TOTP_ICON_URL=
# TTL da tentativa de enrollment MFA em ms.
MFA_ENROLLMENT_TTL_MS=600000
# Diretorio temporario dos exports administrativos.
ADMIN_EXPORTS_DIR=backups/admin-exports
# TTL dos exports administrativos em horas.
ADMIN_EXPORT_TTL_HOURS=24
# Habilita metrics operacionais.
METRICS_ENABLED=false
# Token exigido quando METRICS_ENABLED=true.
METRICS_TOKEN=
# Liga o webhook de alerts operacionais.
OPS_ALERTS_WEBHOOK_ENABLED=false
# Provider do webhook; hoje o suporte oficial e discord.
OPS_ALERTS_WEBHOOK_PROVIDER=discord
# URL do webhook operacional.
OPS_ALERTS_WEBHOOK_URL=
# Timeout do webhook em ms.
OPS_ALERTS_WEBHOOK_TIMEOUT_MS=5000
# Intervalo minimo entre envios do webhook em ms.
OPS_ALERTS_WEBHOOK_INTERVAL_MS=60000
# Latencia de banco que passa a gerar warning em ms.
OPS_ALERTS_DB_LATENCY_WARNING_MS=1000
