---
import "../../src/index.css";
import "../../src/styles/fonts.css";
import { serializeSchemaOrgEntry } from "../../server/lib/schema-org.js";
import type { SiteSettings } from "../../src/types/site-settings";
import PublicChromeIsland from "../components/react/PublicChromeIsland";
import { buildPublicChromeModel } from "../lib/public-layout";

interface Props {
  canonicalUrl?: string;
  description: string;
  image?: string;
  imageAlt?: string;
  robots?: string;
  structuredData?: unknown[];
  title: string;
}

const {
  description: _description,
  image: _image = "",
  imageAlt: _imageAlt = "",
  robots: _robots = "index, follow",
  canonicalUrl: _canonicalUrlProp = "",
  structuredData: _structuredData = [],
  title: _title,
} = Astro.props;
const locals = Astro.locals.nekomata;
const fallbackSettings: SiteSettings = {
  site: {
    name: "Nekomata",
    logoUrl: "",
    faviconUrl: "",
    description: "",
    defaultShareImage: "/placeholder.svg",
    defaultShareImageAlt: "",
    titleSeparator: " | ",
  },
  theme: {
    accent: "#9667e0",
    mode: "dark",
  },
  navbar: { links: [] },
  community: {
    discordUrl: "",
    inviteCard: {
      title: "",
      subtitle: "",
      panelTitle: "",
      panelDescription: "",
      ctaLabel: "",
      ctaUrl: "",
    },
  },
  branding: {
    assets: { symbolUrl: "", wordmarkUrl: "" },
    overrides: {
      navbarSymbolUrl: "",
      footerSymbolUrl: "",
      navbarWordmarkUrl: "",
      footerWordmarkUrl: "",
    },
    display: { navbar: "symbol-text", footer: "symbol-text" },
    wordmarkUrl: "",
    wordmarkUrlNavbar: "",
    wordmarkUrlFooter: "",
    wordmarkPlacement: "both",
    wordmarkEnabled: false,
  },
  downloads: { sources: [] },
  teamRoles: [],
  footer: {
    brandName: "Nekomata",
    brandLogoUrl: "",
    brandDescription: "",
    columns: [],
    socialLinks: [],
    disclaimer: [],
    highlightTitle: "",
    highlightDescription: "",
    copyright: "",
  },
  seo: { redirects: [] },
  reader: {
    projectTypes: {
      manga: null as never,
      webtoon: null as never,
    },
  },
};
const chrome = buildPublicChromeModel(locals?.siteSettings ?? fallbackSettings);
const separator = locals?.siteSettings?.site?.titleSeparator || " | ";
const _pageTitle = _title ? `${_title}${separator}${chrome.siteName}` : chrome.siteName;
const _canonicalUrl =
  _canonicalUrlProp ||
  new URL(
    Astro.url.pathname,
    locals?.primaryAppOrigin || Astro.url.origin || "https://nekomata.moe",
  ).toString();
const _absoluteImage = _image ? new URL(_image, _canonicalUrl).toString() : "";
const _absoluteFavicon = chrome.siteFaviconUrl
  ? new URL(chrome.siteFaviconUrl, _canonicalUrl).toString()
  : "";
const _location = `${Astro.url.pathname}${Astro.url.search}`;
const _hasSurfaceGradient = Astro.url.pathname === "/projetos";
---

<!doctype html>
<html lang="pt-BR" data-page-meta="true" data-page-owner="astro">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{_pageTitle}</title>
    <meta name="description" content={_description} />
    <meta name="robots" content={_robots} />
    <meta name="theme-color" content={chrome.themeColor} />
    <meta property="og:title" content={_pageTitle} />
    <meta property="og:description" content={_description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={_canonicalUrl} />
    <meta property="og:site_name" content={chrome.siteName} />
    <meta property="og:locale" content="pt_BR" />
    {_absoluteImage ? <meta property="og:image" content={_absoluteImage} /> : null}
    {_imageAlt ? <meta property="og:image:alt" content={_imageAlt} /> : null}
    <meta name="twitter:title" content={_pageTitle} />
    <meta name="twitter:description" content={_description} />
    <meta name="twitter:card" content={_image ? "summary_large_image" : "summary"} />
    {_absoluteImage ? <meta name="twitter:image" content={_absoluteImage} /> : null}
    {_imageAlt ? <meta name="twitter:image:alt" content={_imageAlt} /> : null}
    <link rel="canonical" href={_canonicalUrl} />
    {_absoluteFavicon ? <link rel="icon" href={_absoluteFavicon} /> : null}
    {
      Array.isArray(_structuredData)
        ? _structuredData
            .filter((entry) => entry && typeof entry === "object")
            .map((entry) => (
              <script
                is:inline
                type="application/ld+json"
                data-schema-org="true"
                set:html={serializeSchemaOrgEntry(entry)}
              />
            ))
        : null
    }
  </head>
  <body class="min-h-screen bg-background text-foreground">
    <div class:list={["flex min-h-screen flex-col bg-background text-foreground", _hasSurfaceGradient && "bg-gradient-surface"]}>
      <PublicChromeIsland
        client:load
        kind="header"
        location={_location}
        initialCurrentUser={locals?.currentUser ?? null}
        initialPublicBootstrap={locals?.publicBootstrap || null}
        initialPublicRoutePayload={locals?.routePayload || null}
        initialSettings={locals?.siteSettings || null}
      />

      <main id="public-main-content" tabindex="-1" class="a11y-focus-target flex-1 page-transition">
        <slot />
      </main>

      <PublicChromeIsland
        client:load
        kind="footer"
        location={_location}
        initialCurrentUser={locals?.currentUser ?? null}
        initialPublicBootstrap={locals?.publicBootstrap || null}
        initialPublicRoutePayload={locals?.routePayload || null}
        initialSettings={locals?.siteSettings || null}
      />
    </div>
  </body>
</html>
