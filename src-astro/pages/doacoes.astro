---
/* biome-ignore-all lint/correctness/noUnusedVariables: Astro template consumes frontmatter bindings. */
import { buildMonthlyGoalSummary } from "../../src/lib/donations-monthly-goal";
import {
  DEFAULT_DONATIONS_CRYPTO_ACTION_LABEL,
  getDonationsCryptoMeta,
  isRenderableDonationsCryptoService,
  normalizeDonationsCryptoServices,
} from "../../src/lib/donations-crypto";
import { sanitizePublicHref } from "../../src/lib/url-safety";
import type { PublicRouteDonationsPayload } from "../../src/types/public-bootstrap";
import type { DonationsPageConfig } from "../../src/types/public-pages";
import { emptyPublicPagesConfig } from "../../src/types/public-pages";
import PublicPageHero from "../components/PublicPageHero.astro";
import { buildInstitutionalPageMeta } from "../lib/public-page-meta";
import { astroStaticRevealClassName } from "../lib/public-reveal";
import PublicLayout from "../layouts/PublicLayout.astro";

const locals = Astro.locals.nekomata;
const meta = buildInstitutionalPageMeta({
  pageKey: "donations",
  pages: locals?.pages,
  siteSettings: locals?.siteSettings,
});

const routePayload =
  locals?.routePayload && locals.routePayload.kind === "donations"
    ? (locals.routePayload as PublicRouteDonationsPayload)
    : null;

const donations = {
  ...emptyPublicPagesConfig.donations,
  ...(locals?.pages?.donations || {}),
} as DonationsPageConfig;
const visibleCryptoServices = normalizeDonationsCryptoServices(donations.cryptoServices).filter(
  (service) => isRenderableDonationsCryptoService(service),
);
const monthlyGoal = buildMonthlyGoalSummary({
  raised: donations.monthlyGoalRaised,
  target: donations.monthlyGoalTarget,
  supporters: donations.monthlyGoalSupporters,
  note: donations.monthlyGoalNote,
});
const pixQrUrl = String(routePayload?.pixQrCodeUrl || donations.qrCustomUrl || "").trim();
const getCryptoQrUrl = (index: number) =>
  String(routePayload?.cryptoQrCodeUrls?.[String(index)] || "").trim();
---

<PublicLayout title={meta.title || "Doacoes"} description={meta.description} image={meta.image} imageAlt={meta.imageAlt}>
  <div class="min-h-screen bg-background text-foreground">
    <main>
      <PublicPageHero title={donations.heroTitle || "Doacoes"} subtitle={donations.heroSubtitle} />

      {Array.isArray(donations.costs) && donations.costs.length > 0 ? (
        <section class={`mx-auto grid w-full max-w-6xl gap-6 px-6 pb-12 pt-10 md:grid-cols-3 md:px-10 ${astroStaticRevealClassName}`} data-reveal>
          {donations.costs.map((item) => (
            <article class="stacked-surface stacked-surface--public stacked-surface--interactive group rounded-2xl border border-border/60 bg-card/80 p-6">
              <p class="flex items-center gap-3 text-sm font-semibold uppercase tracking-widest text-muted-foreground transition-colors duration-300 group-hover:text-primary">
                <span class="h-2 w-2 rounded-full bg-primary/80"></span>
                {item.title}
              </p>
              <p class="mt-3 whitespace-pre-wrap text-sm text-muted-foreground transition-colors duration-300 group-hover:text-foreground/80">
                {item.description}
              </p>
            </article>
          ))}
        </section>
      ) : null}

      {monthlyGoal ? (
        <section class={`mx-auto w-full max-w-6xl px-6 pb-8 pt-2 md:px-10 ${astroStaticRevealClassName}`} data-reveal>
          <article class:list={[
            "stacked-surface stacked-surface--public rounded-2xl p-6 md:p-8",
            monthlyGoal.isComplete ? "border-primary/30 bg-primary/5" : "border-border/60 bg-card/90",
          ]}>
            <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
              <div class="space-y-3">
                <div class="flex flex-wrap items-center gap-2">
                  <p class:list={[
                    "text-sm font-semibold uppercase tracking-widest",
                    monthlyGoal.isComplete ? "text-primary" : "text-muted-foreground",
                  ]}>
                    {monthlyGoal.title}
                  </p>
                  {monthlyGoal.isComplete ? (
                    <span class="rounded-full border border-primary/15 bg-primary/10 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-[0.12em] text-primary">
                      Concluida
                    </span>
                  ) : null}
                </div>
                <p class="text-lg font-semibold text-foreground md:text-xl">
                  {monthlyGoal.raisedLabel}
                  <span class="ml-2 font-medium text-muted-foreground">de {monthlyGoal.targetLabel}</span>
                </p>
                <p class:list={[
                  "text-sm",
                  monthlyGoal.isComplete ? "text-primary" : "text-muted-foreground",
                ]}>
                  {monthlyGoal.statusText}
                </p>
              </div>
              <div class="flex flex-col items-start gap-1.5 md:items-end">
                <span class:list={[
                  "text-3xl font-semibold",
                  monthlyGoal.isComplete ? "text-primary" : "text-foreground",
                ]}>
                  {monthlyGoal.percentage}%
                </span>
                {monthlyGoal.supportersLabel ? (
                  <div class="text-xs font-medium text-muted-foreground">{monthlyGoal.supportersLabel}</div>
                ) : null}
              </div>
            </div>

            {monthlyGoal.note ? (
              <div class:list={[
                "mt-5 whitespace-pre-wrap rounded-2xl border px-4 py-3 text-sm",
                monthlyGoal.isComplete
                  ? "border-primary/15 bg-background/80 text-foreground/80"
                  : "border-border/60 bg-background/60 text-muted-foreground",
              ]}>
                {monthlyGoal.note}
              </div>
            ) : null}

            <div class="mt-5 h-3 overflow-hidden rounded-full bg-primary/15">
              <div
                class:list={[
                  "h-full rounded-full bg-primary",
                  monthlyGoal.isComplete ? "shadow-primary-glow" : "",
                ]}
                style={`width:${monthlyGoal.percentage}%`}
              ></div>
            </div>
          </article>
        </section>
      ) : null}

      {donations.reasonTitle || donations.reasonText || donations.pixKey ? (
        <section class={`mx-auto w-full max-w-6xl px-6 pb-12 pt-0 md:px-10 ${astroStaticRevealClassName}`} data-reveal>
          <article class="stacked-surface stacked-surface--public rounded-2xl border border-border/60 bg-card/90 p-6 md:p-8">
            <div class:list={[
              "grid gap-6",
              (donations.reasonTitle || donations.reasonText) && donations.pixKey
                ? "md:grid-cols-[1.1fr_0.9fr]"
                : "md:grid-cols-1",
            ]}>
              {donations.reasonTitle || donations.reasonText ? (
                <div class="space-y-4 rounded-2xl p-2">
                  <p class="flex items-center gap-3 text-sm font-semibold uppercase tracking-widest text-muted-foreground">
                    <span class="h-2 w-2 rounded-full bg-primary/80"></span>
                    {donations.reasonTitle}
                  </p>
                  <p class="whitespace-pre-wrap text-sm text-muted-foreground md:text-base">
                    {donations.reasonText}
                  </p>
                  {donations.reasonNote ? (
                    <div class="whitespace-pre-wrap rounded-2xl border border-border/60 bg-background/60 p-4 text-sm text-muted-foreground">
                      {donations.reasonNote}
                    </div>
                  ) : null}
                </div>
              ) : null}

              {donations.pixKey ? (
                <div id="pix-doacoes" class="rounded-2xl border border-border/60 bg-background/50 p-5">
                  <div class="flex items-center justify-between">
                    <div class="flex items-center gap-2 text-sm font-semibold uppercase tracking-widest text-muted-foreground">
                      <span class="h-2 w-2 rounded-full bg-primary/80"></span>
                      PIX
                    </div>
                    <span class="text-xs text-muted-foreground">Chave e QR Code</span>
                  </div>
                  <div class="mt-4 grid gap-4 md:grid-cols-[0.8fr_1.2fr] md:items-center">
                    {pixQrUrl ? (
                      <div class="mx-auto w-full max-w-[220px] p-0 md:mx-0">
                        <div class="overflow-hidden rounded-[1.2rem] border border-border/40 bg-white p-2">
                          <img src={pixQrUrl} alt="QR Code PIX" class="aspect-square w-full rounded-lg object-cover" />
                        </div>
                      </div>
                    ) : null}
                    <div class="space-y-3">
                      <div class="min-w-0 break-all text-center font-mono text-sm leading-relaxed text-primary">
                        {donations.pixKey}
                      </div>
                      <div class="flex w-full flex-wrap items-center gap-3 md:justify-center">
                        <button
                          type="button"
                          class="inline-flex w-full items-center justify-center rounded-xl bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground transition hover:opacity-90 md:w-auto"
                          data-copy-text={donations.pixKey}
                        >
                          Copiar chave PIX
                        </button>
                      </div>
                    </div>
                  </div>
                </div>
              ) : null}
            </div>
          </article>
        </section>
      ) : null}

      {visibleCryptoServices.length > 0 ? (
        <section class={`mx-auto w-full max-w-6xl px-6 pb-8 pt-0 md:px-10 ${astroStaticRevealClassName}`} data-reveal>
          <article class="stacked-surface stacked-surface--public rounded-2xl border-0 bg-card/90 p-5 shadow-public-card md:p-6">
            <div class:list={[
              "grid gap-4",
              visibleCryptoServices.length > 1
                ? "md:grid-cols-[60px_minmax(0,1fr)] lg:grid-cols-[64px_minmax(0,1fr)]"
                : "",
            ]}>
              {visibleCryptoServices.length > 1 ? (
                <div class="min-w-0">
                  <div
                    role="tablist"
                    aria-label="Criptomoedas"
                    class="no-scrollbar flex gap-2 overflow-x-auto pb-0.5 md:flex-col md:gap-1.5 md:overflow-visible md:pb-0"
                  >
                    {visibleCryptoServices.map((service, index) => (
                      <button
                        type="button"
                        role="tab"
                        id={`donations-crypto-tab-${index}`}
                        aria-controls={`donations-crypto-panel-${index}`}
                        aria-selected={index === 0 ? "true" : "false"}
                        data-crypto-tab
                        data-crypto-index={index}
                        class:list={[
                          "group relative flex h-12 w-12 shrink-0 items-center justify-center overflow-hidden rounded-[1.1rem] border transition-all duration-300 md:h-13 md:w-13",
                          index === 0
                            ? "border-primary/50 text-primary"
                            : "border-border/50 text-muted-foreground hover:border-primary/40 hover:text-foreground",
                        ]}
                      >
                        <span class:list={[
                          "absolute inset-y-3 left-0 hidden w-1 rounded-full bg-primary transition-opacity md:block",
                          index === 0 ? "opacity-100" : "opacity-0",
                        ]}></span>
                        <span class="text-[10px] font-semibold uppercase tracking-[0.12em]">
                          {String(service.name || "?").slice(0, 2).toUpperCase()}
                        </span>
                      </button>
                    ))}
                  </div>
                </div>
              ) : null}

              <div class="space-y-4">
                {visibleCryptoServices.map((service, index) => {
                  const actionUrl = sanitizePublicHref(service.actionUrl);
                  const metaLabel = getDonationsCryptoMeta(service);
                  const qrUrl = getCryptoQrUrl(index);
                  return (
                    <section
                      role={visibleCryptoServices.length > 1 ? "tabpanel" : undefined}
                      id={`donations-crypto-panel-${index}`}
                      aria-labelledby={visibleCryptoServices.length > 1 ? `donations-crypto-tab-${index}` : undefined}
                      data-crypto-panel
                      data-crypto-index={index}
                      hidden={index === 0 ? undefined : true}
                    >
                      <div class="grid gap-6 md:grid-cols-[minmax(0,1fr)_188px] md:items-start">
                        <div class="min-w-0 space-y-5">
                          <div class="min-w-0 space-y-1.5">
                            <div class="inline-flex max-w-full items-start gap-1.5">
                              <div class="min-w-0 text-base font-semibold text-foreground md:text-lg">
                                {service.name}
                              </div>
                              {actionUrl ? (
                                <a
                                  href={actionUrl}
                                  target="_blank"
                                  rel="noreferrer noopener"
                                  class="ml-1.5 inline-flex h-6 w-6 shrink-0 items-center justify-center text-muted-foreground transition-colors duration-300 hover:text-accent"
                                  aria-label={service.actionLabel || DEFAULT_DONATIONS_CRYPTO_ACTION_LABEL}
                                  title={service.actionLabel || DEFAULT_DONATIONS_CRYPTO_ACTION_LABEL}
                                >
                                  ↗
                                </a>
                              ) : null}
                            </div>
                            {metaLabel ? (
                              <div class="text-[11px] font-medium uppercase tracking-[0.18em] text-muted-foreground">
                                {metaLabel}
                              </div>
                            ) : null}
                          </div>

                          <div class="space-y-2">
                            <div class="text-[11px] font-medium uppercase tracking-[0.18em] text-muted-foreground">
                              Endereco
                            </div>
                            <div class="min-w-0 text-sm leading-relaxed">
                              <p class="inline min-w-0 break-all font-mono text-sm text-primary">
                                {service.address}
                              </p>
                              <button
                                type="button"
                                class="ml-1.5 inline-flex h-6 w-6 shrink-0 items-center justify-center text-muted-foreground transition-colors duration-300 hover:text-accent"
                                data-copy-text={service.address}
                                aria-label="Copiar endereco"
                                title="Copiar endereco"
                              >
                                ⧉
                              </button>
                            </div>
                          </div>

                          {service.note ? (
                            <div class="space-y-2">
                              <div class="text-[11px] font-medium uppercase tracking-[0.18em] text-muted-foreground">
                                Observacoes
                              </div>
                              <p class="whitespace-pre-wrap text-sm leading-relaxed text-muted-foreground">
                                {service.note}
                              </p>
                            </div>
                          ) : null}
                        </div>

                        {qrUrl ? (
                          <div class="space-y-3 md:justify-self-end md:self-start">
                            <div class="mx-auto w-full max-w-[188px] p-0 md:mx-0">
                              <div class="overflow-hidden rounded-[1.2rem] border border-border/40 bg-white p-2">
                                <img src={qrUrl} alt={`QR Code ${service.name}`} class="aspect-square w-full rounded-lg object-cover" />
                              </div>
                            </div>
                          </div>
                        ) : null}
                      </div>
                    </section>
                  );
                })}
              </div>
            </div>
          </article>
        </section>
      ) : null}

      {Array.isArray(donations.donors) && donations.donors.length > 0 ? (
        <section class={`mx-auto w-full max-w-6xl px-6 pb-24 pt-4 md:px-10 ${astroStaticRevealClassName}`} data-reveal>
          <article class="stacked-surface stacked-surface--public rounded-2xl bg-card/80 p-6 shadow-public-card md:p-8">
            <div class="flex items-center gap-3 text-xl font-semibold text-foreground">
              <span class="h-2 w-2 rounded-full bg-primary/80"></span>
              Lista de doadores
            </div>
            <div class="my-6 h-px bg-border/60"></div>
            <div class="overflow-x-auto">
              <table class="w-full text-left text-sm">
                <colgroup>
                  <col class="w-[34%]" />
                  <col class="w-[22%]" />
                  <col class="w-[28%]" />
                  <col class="w-[16%]" />
                </colgroup>
                <thead class="text-xs uppercase tracking-widest text-muted-foreground">
                  <tr>
                    <th class="pb-3">Doador</th>
                    <th class="pb-3">Valor</th>
                    <th class="pb-3">Objetivo</th>
                    <th class="pb-3">Mes/Ano</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-border/40">
                  {donations.donors.map((donor) => (
                    <tr>
                      <td class="py-3 font-medium text-foreground">{donor.name}</td>
                      <td class="py-3 text-muted-foreground">{donor.amount}</td>
                      <td class="py-3 text-muted-foreground">{donor.goal}</td>
                      <td class="py-3 text-muted-foreground">{donor.date}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </article>
        </section>
      ) : null}
    </main>
  </div>

  <script is:inline>
    const updateCopyButtonState = (button, copied) => {
      if (!(button instanceof HTMLButtonElement)) {
        return;
      }
      if (!button.dataset.copyBaseLabel) {
        button.dataset.copyBaseLabel = button.textContent || "Copiar";
      }
      button.textContent = copied ? "Copiado" : button.dataset.copyBaseLabel;
    };

    document.addEventListener("click", async (event) => {
      const copyButton = event.target instanceof Element
        ? event.target.closest("[data-copy-text]")
        : null;
      if (copyButton instanceof HTMLButtonElement) {
        const value = String(copyButton.getAttribute("data-copy-text") || "").trim();
        if (!value) {
          return;
        }
        let copied = false;
        try {
          await navigator.clipboard.writeText(value);
          copied = true;
        } catch {
          const textarea = document.createElement("textarea");
          textarea.value = value;
          textarea.setAttribute("readonly", "");
          textarea.style.position = "fixed";
          textarea.style.left = "-9999px";
          document.body.appendChild(textarea);
          textarea.focus();
          textarea.select();
          copied = document.execCommand("copy");
          document.body.removeChild(textarea);
        }
        updateCopyButtonState(copyButton, copied);
        if (copied) {
          window.setTimeout(() => updateCopyButtonState(copyButton, false), 2000);
        }
        return;
      }

      const tab = event.target instanceof Element ? event.target.closest("[data-crypto-tab]") : null;
      if (!(tab instanceof HTMLButtonElement)) {
        return;
      }
      const activeIndex = String(tab.getAttribute("data-crypto-index") || "");
      for (const candidate of document.querySelectorAll("[data-crypto-tab]")) {
        if (!(candidate instanceof HTMLButtonElement)) {
          continue;
        }
        const isActive = String(candidate.getAttribute("data-crypto-index") || "") === activeIndex;
        candidate.setAttribute("aria-selected", isActive ? "true" : "false");
        candidate.classList.toggle("border-primary/50", isActive);
        candidate.classList.toggle("text-primary", isActive);
        candidate.classList.toggle("border-border/50", !isActive);
        candidate.classList.toggle("text-muted-foreground", !isActive);
        const rail = candidate.querySelector("span");
        if (rail instanceof HTMLElement) {
          rail.classList.toggle("opacity-100", isActive);
          rail.classList.toggle("opacity-0", !isActive);
        }
      }
      for (const panel of document.querySelectorAll("[data-crypto-panel]")) {
        if (!(panel instanceof HTMLElement)) {
          continue;
        }
        panel.hidden = String(panel.getAttribute("data-crypto-index") || "") !== activeIndex;
      }
    });
  </script>
</PublicLayout>
