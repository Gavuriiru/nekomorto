---
import ProjectHero from "../../../src/components/project/ProjectHero";
import { canManageProjectsAccess } from "../../../src/lib/access-control";
import { buildProjectPublicReadingHref } from "../../../src/lib/project-editor-routes";
import {
  buildTranslationMap,
  sortByTranslatedLabel,
  translateTag,
} from "../../../src/lib/project-taxonomy";
import { hasPublicEpisodeReadableContent } from "../../../src/lib/public-project-episodes";
import { isChapterBasedType } from "../../../src/lib/project-utils";
import type { PublicRouteProjectDetailPayload } from "../../../src/types/public-bootstrap";
import PublicSiteIslandApp from "../../components/react/PublicSiteIslandApp";
import PublicLayout from "../../layouts/PublicLayout.astro";
import { resolveProjectPageMeta } from "../../lib/public-phase3-meta";

const locals = Astro.locals.nekomata;
const publicBootstrap = locals?.publicBootstrap || null;
const siteSettings = locals?.siteSettings;
const routePayload =
  locals?.routePayload && locals.routePayload.kind === "project-detail"
    ? (locals.routePayload as PublicRouteProjectDetailPayload)
    : null;
const project = routePayload?.project || null;
const tagTranslationMap = buildTranslationMap(routePayload?.tagTranslations?.tags || {});
const translatedTags = project
  ? sortByTranslatedLabel(project.tags || [], (tag) => translateTag(tag, tagTranslationMap)).map(
      (tag) => ({
        href: `/projetos?tag=${encodeURIComponent(tag)}`,
        key: tag,
        label: translateTag(tag, tagTranslationMap),
      }),
    )
  : [];
const compareReadableEpisodeOrdering = (
  left: { number?: number; volume?: number; readingOrder?: number },
  right: { number?: number; volume?: number; readingOrder?: number },
) => {
  const leftReadingOrder = Number(left?.readingOrder);
  const rightReadingOrder = Number(right?.readingOrder);
  const hasLeftReadingOrder = Number.isFinite(leftReadingOrder);
  const hasRightReadingOrder = Number.isFinite(rightReadingOrder);
  if (hasLeftReadingOrder || hasRightReadingOrder) {
    if (!hasLeftReadingOrder) {
      return 1;
    }
    if (!hasRightReadingOrder) {
      return -1;
    }
    if (leftReadingOrder !== rightReadingOrder) {
      return leftReadingOrder - rightReadingOrder;
    }
  }
  const numberDelta = (left.number || 0) - (right.number || 0);
  if (numberDelta !== 0) {
    return numberDelta;
  }
  return (left.volume || 0) - (right.volume || 0);
};
const isChapterBased = isChapterBasedType(project?.type || "");
const firstReadableChapter =
  project?.episodeDownloads
    ?.filter((episode) => hasPublicEpisodeReadableContent(episode))
    ?.sort(compareReadableEpisodeOrdering)?.[0] || null;
const canEditProject = canManageProjectsAccess(locals?.currentUser ?? null);
const renderAstroHero = Boolean(project);
type HeroActionItem = {
  href: string;
  key: string;
  label: string;
  variant: "default" | "outline" | "secondary";
  external?: boolean;
  className?: string;
};
const heroActionItems: HeroActionItem[] = [];
if (project) {
  heroActionItems.push({
    href: "#downloads",
    key: "downloads",
    label: isChapterBased ? "Ver capítulos" : "Ver episódios",
    variant: "default",
  });
  if (project.trailerUrl) {
    heroActionItems.push({
      href: project.trailerUrl,
      key: "trailer",
      label: "Assistir trailer",
      variant: "outline",
      external: true,
    });
  }
  if (canEditProject) {
    heroActionItems.push({
      href: `/dashboard/projetos?edit=${encodeURIComponent(project.id)}`,
      key: "edit",
      label: "Editar projeto",
      variant: "secondary",
    });
  }
  if (isChapterBased && firstReadableChapter) {
    heroActionItems.push({
      href: buildProjectPublicReadingHref(
        project.id,
        firstReadableChapter.number,
        firstReadableChapter.volume,
      ),
      key: "read",
      label: "Começar leitura",
      variant: "outline",
      className: "order-last",
    });
  }
}
const staticProjectHeroId = "public-phase3-project-hero";
const _meta = resolveProjectPageMeta({
  fallbackOrigin: locals?.primaryAppOrigin || Astro.url.origin,
  pathname: Astro.url.pathname,
  publicBootstrap,
  routePayload,
  siteSettings,
});
---

<PublicLayout
  canonicalUrl={_meta.canonicalUrl}
  description={_meta.description}
  image={_meta.image}
  imageAlt={_meta.imageAlt}
  structuredData={_meta.structuredData}
  title={_meta.title}
>
  {
    renderAstroHero ? (
      <div id={staticProjectHeroId}>
        <ProjectHero
          actionItems={heroActionItems}
          project={project!}
          mediaVariants={routePayload?.mediaVariants || {}}
          tagItems={translatedTags}
        />
      </div>
    ) : null
  }
  <PublicSiteIslandApp
    client:load
    initialPath={`${Astro.url.pathname}${Astro.url.search}`}
    initialCurrentUser={locals?.currentUser ?? null}
    initialProjectSlug={Astro.params.slug || ""}
    initialPublicBootstrap={publicBootstrap}
    initialPublicRoutePayload={locals?.routePayload || null}
    initialSettings={locals?.siteSettings || null}
    staticProjectHeroId={renderAstroHero ? staticProjectHeroId : undefined}
  />
</PublicLayout>
