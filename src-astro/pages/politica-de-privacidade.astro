---
/* biome-ignore-all lint/correctness/noUnusedVariables: Astro template consumes frontmatter bindings. */
import PublicSiteIslandApp from "../components/react/PublicSiteIslandApp";
import PublicLayout from "../layouts/PublicLayout.astro";
import { buildInstitutionalPageMeta } from "../lib/public-page-meta";

const locals = Astro.locals.nekomata;
const meta = buildInstitutionalPageMeta({
  pageKey: "privacy",
  pages: locals?.pages,
  siteSettings: locals?.siteSettings,
});
const staticShellRootId = "public-privacy-route-shell";
---

<PublicLayout
  title="Politica de Privacidade"
  description={meta.description}
  image={meta.image}
  imageAlt={meta.imageAlt}
>
  <section id={staticShellRootId} class="mx-auto max-w-3xl px-6 pb-20 pt-16 md:px-8 md:pt-24">
    <div class="space-y-10 rounded-3xl border border-border/60 bg-card/75 p-6 shadow-sm md:p-8">
      <header class="space-y-3">
        <p class="text-xs font-semibold uppercase tracking-[0.24em] text-muted-foreground">
          Informacoes legais
        </p>
        <h1 class="text-3xl font-semibold tracking-tight md:text-4xl">Politica de Privacidade</h1>
        <p class="text-sm leading-relaxed text-muted-foreground md:text-base">
          Esta Politica de Privacidade explica, de forma objetiva, como tratamos dados ligados ao
          uso do site, aos comentarios publicos, a autenticacao e a operacao da plataforma.
        </p>
      </header>

      <section class="space-y-3">
        <h2 class="text-lg font-semibold">1. Dados fornecidos por voce</h2>
        <p class="text-sm leading-relaxed text-muted-foreground md:text-base">
          Ao enviar um comentario publico, podemos tratar o nome escolhido, o conteudo enviado e
          um e-mail opcional. Tambem podem ser processados dados de contexto do proprio comentario,
          como a pagina ou item ao qual ele esta vinculado.
        </p>
      </section>

      <section class="space-y-3">
        <h2 class="text-lg font-semibold">2. Comentarios e avatar</h2>
        <p class="text-sm leading-relaxed text-muted-foreground md:text-base">
          Comentarios aprovados podem exibir publicamente o nome informado, o conteudo enviado, a
          data da publicacao e o avatar associado ao comentario. Quando o e-mail opcional e
          informado, ele pode ser usado para obter avatar por meio do Gravatar.
        </p>
      </section>

      <section class="space-y-3">
        <h2 class="text-lg font-semibold">3. Login e areas restritas</h2>
        <p class="text-sm leading-relaxed text-muted-foreground md:text-base">
          Para acesso a areas restritas da plataforma, podemos tratar dados de autenticacao
          fornecidos por provedores autorizados, como Google e Discord, alem das informacoes
          necessarias para sessao, seguranca e controle de acesso.
        </p>
        <p class="text-sm leading-relaxed text-muted-foreground md:text-base">
          O login com Google e usado para autenticar usuarios autorizados da equipe no dashboard e
          em outras areas internas. Esse login nao e necessario para visitantes navegarem pelas
          paginas publicas do site.
        </p>
      </section>

      <section class="space-y-3">
        <h2 class="text-lg font-semibold">4. Seguranca e operacao</h2>
        <p class="text-sm leading-relaxed text-muted-foreground md:text-base">
          Dados tecnicos e operacionais podem ser tratados para autenticacao, manutencao de sessao,
          moderacao, prevencao de spam, rate limiting, seguranca, diagnostico e operacao geral do
          servico. Isso pode incluir registros tecnicos e identificadores necessarios para proteger
          a plataforma.
        </p>
      </section>

      <section class="space-y-3">
        <h2 class="text-lg font-semibold">5. Retencao e terceiros</h2>
        <p class="text-sm leading-relaxed text-muted-foreground md:text-base">
          Os dados podem ser mantidos pelo tempo necessario para operacao do site, moderacao,
          seguranca e cumprimento de obrigacoes aplicaveis. Quando houver uso de servicos de
          terceiros, como autenticacao externa ou avatar, o tratamento correspondente tambem pode
          seguir as politicas proprias desses servicos.
        </p>
      </section>

      <section class="space-y-3">
        <h2 class="text-lg font-semibold">6. Atualizacoes desta politica</h2>
        <p class="text-sm leading-relaxed text-muted-foreground md:text-base">
          Esta Politica de Privacidade pode ser atualizada para refletir mudancas tecnicas,
          operacionais ou legais. A versao publicada nesta pagina sera considerada a versao
          vigente.
        </p>
      </section>
    </div>
  </section>
  <PublicSiteIslandApp
    client:load
    initialPath={`${Astro.url.pathname}${Astro.url.search}`}
    initialCurrentUser={locals?.currentUser ?? null}
    initialPublicBootstrap={locals?.publicBootstrap || null}
    initialPublicRoutePayload={locals?.routePayload || null}
    initialSettings={locals?.siteSettings || null}
    staticShellRootId={staticShellRootId}
  />
</PublicLayout>
