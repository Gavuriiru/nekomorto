---
import PublicTeamPageContent from "../../src/components/public-pages/PublicTeamPageContent";
import type { PublicRouteTeamPayload } from "../../src/types/public-bootstrap";
import { emptyPublicPagesConfig } from "../../src/types/public-pages";
import { buildInstitutionalPageMeta } from "../lib/public-page-meta";
import PublicLayout from "../layouts/PublicLayout.astro";

const locals = Astro.locals.nekomata;
const meta = buildInstitutionalPageMeta({
  pageKey: "team",
  pages: locals?.pages,
  siteSettings: locals?.siteSettings,
});

const routePayload =
  locals?.routePayload && locals.routePayload.kind === "team"
    ? (locals.routePayload as PublicRouteTeamPayload)
    : null;

const teamPage = {
  ...emptyPublicPagesConfig.team,
  heroBadge: "Equipe",
  heroTitle: "Conheça quem faz o projeto acontecer",
  heroSubtitle:
    "Os perfis e redes sociais são gerenciados pela dashboard. Esta página já sai consistente no caminho Astro de produção.",
  retiredTitle: "Membros aposentados",
  retiredSubtitle: "Agradecemos por todas as contribuições.",
  ...(locals?.pages?.team || {}),
};
---

<PublicLayout title={meta.title || "Equipe"} description={meta.description} image={meta.image} imageAlt={meta.imageAlt}>
  <PublicTeamPageContent
    client:load
    isLoading={false}
    linkTypes={routePayload?.teamLinkTypes || []}
    mediaVariants={routePayload?.mediaVariants || {}}
    members={routePayload?.teamMembers || []}
    pageCopy={teamPage}
    siteSettings={locals?.siteSettings || null}
  />
</PublicLayout>
