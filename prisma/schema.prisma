generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model PostRecord {
  id          String    @id
  position    Int       @default(0)
  slug        String    @unique
  projectId   String    @default("")
  status      String    @default("draft")
  publishedAt DateTime?
  deletedAt   DateTime?
  data        Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([position])
  @@index([status])
  @@map("posts")
}

model PostVersionRecord {
  id          String   @id
  postId       String
  position     Int      @default(0)
  versionNumber Int
  reason       String
  label        String?
  actorId      String?
  actorName    String?
  slug         String
  createdAt    DateTime
  data         Json

  @@index([position])
  @@index([postId, createdAt])
  @@index([postId, versionNumber])
  @@map("post_versions")
}

model ProjectRecord {
  id        String    @id
  position  Int       @default(0)
  deletedAt DateTime?
  data      Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([position])
  @@map("projects")
}

model UserRecord {
  id         String   @id
  position   Int      @default(0)
  accessRole String?
  status     String?
  data       Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([position])
  @@index([accessRole])
  @@map("users")
}

model CommentRecord {
  id         String    @id
  position   Int       @default(0)
  targetType String
  targetId   String
  status     String
  createdAt  DateTime?
  data       Json
  updatedAt  DateTime  @updatedAt

  @@index([position])
  @@index([targetType, targetId])
  @@map("comments")
}

model UpdateRecord {
  id        String    @id
  position  Int       @default(0)
  projectId String
  updatedAt DateTime?
  data      Json

  @@index([position])
  @@index([projectId])
  @@map("updates")
}

model UploadRecord {
  id        String    @id
  position  Int       @default(0)
  url       String    @unique
  folder    String
  createdAt DateTime?
  data      Json
  updatedAt DateTime  @updatedAt

  @@index([position])
  @@index([folder])
  @@map("uploads")
}

model LinkTypeRecord {
  id       String   @id
  position Int      @default(0)
  label    String
  icon     String
  data     Json
  updatedAt DateTime @updatedAt

  @@index([position])
  @@map("link_types")
}

model OwnerIdRecord {
  userId   String @id
  position Int    @unique

  @@index([position])
  @@map("owner_ids")
}

model AllowedUserRecord {
  userId   String @id
  position Int    @default(0)

  @@index([position])
  @@map("allowed_users")
}

model SiteSettingsRecord {
  id        Int      @id @default(1)
  data      Json
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

model IntegrationSettingsRecord {
  id        Int      @id @default(1)
  data      Json
  updatedAt DateTime @updatedAt

  @@map("integration_settings")
}

model PagesRecord {
  id        Int      @id @default(1)
  data      Json
  updatedAt DateTime @updatedAt

  @@map("pages")
}

model TagTranslationsRecord {
  id        Int      @id @default(1)
  data      Json
  updatedAt DateTime @updatedAt

  @@map("tag_translations")
}

model AuditLogRecord {
  id        String   @id
  position  Int      @default(0)
  ts        DateTime
  actorId   String
  actorName String
  ip        String
  action    String
  resource  String
  resourceId String?
  status    String
  requestId String?
  data      Json

  @@index([position])
  @@index([ts])
  @@index([action])
  @@map("audit_logs")
}

model AnalyticsEventRecord {
  id              String   @id
  position        Int      @default(0)
  ts              DateTime
  day             DateTime @db.Date
  eventType       String
  resourceType    String
  resourceId      String
  visitorHash     String
  referrerHost    String
  isAuthenticated Boolean  @default(false)
  data            Json

  @@index([position])
  @@index([day])
  @@index([resourceType, resourceId])
  @@index([ts])
  @@map("analytics_events")
}

model AnalyticsDailyRecord {
  id            Int      @id @default(1)
  schemaVersion Int
  generatedAt   DateTime
  data          Json
  updatedAt     DateTime @updatedAt

  @@map("analytics_daily")
}

model AnalyticsMetaRecord {
  id                   Int      @id @default(1)
  schemaVersion        Int
  retentionDays        Int
  aggregateRetentionDays Int
  updatedAt            DateTime
  data                 Json

  @@map("analytics_meta")
}

model UserSessionRecord {
  sid    String   @id @db.VarChar(255)
  sess   Json
  expire DateTime @db.Timestamp(6)

  @@index([expire], map: "idx_user_sessions_expire")
  @@map("user_sessions")
}

model UserMfaTotpRecord {
  userId              String   @id
  secretEncrypted     String
  secretKeyId         String
  enabledAt           DateTime?
  disabledAt          DateTime?
  recoveryCodesHashed Json
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@map("user_mfa_totp")
}

model UserSessionIndexRecord {
  sid          String   @id @db.VarChar(255)
  userId       String
  createdAt    DateTime @default(now())
  lastSeenAt   DateTime
  lastIp       String?
  userAgent    String?
  revokedAt    DateTime?
  revokedBy    String?
  revokeReason String?
  isPendingMfa Boolean  @default(false)

  @@index([userId], map: "user_session_index_userId_idx")
  @@index([lastSeenAt], map: "user_session_index_lastSeenAt_idx")
  @@index([revokedAt], map: "user_session_index_revokedAt_idx")
  @@map("user_session_index")
}

model SecurityEventRecord {
  id           String   @id
  ts           DateTime @default(now())
  type         String
  severity     String
  riskScore    Int      @default(0)
  status       String
  actorUserId  String?
  targetUserId String?
  ip           String?
  userAgent    String?
  sessionId    String?
  requestId    String?
  data         Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([ts], map: "security_events_ts_idx")
  @@index([status], map: "security_events_status_idx")
  @@index([severity], map: "security_events_severity_idx")
  @@index([type], map: "security_events_type_idx")
  @@index([actorUserId], map: "security_events_actorUserId_idx")
  @@index([targetUserId], map: "security_events_targetUserId_idx")
  @@map("security_events")
}

model AdminExportJobRecord {
  id          String   @id
  dataset     String
  format      String
  status      String
  requestedBy String
  filters     Json
  filePath    String?
  rowCount    Int?
  error       String?
  createdAt   DateTime @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?
  expiresAt   DateTime?
  updatedAt   DateTime @updatedAt

  @@index([status], map: "admin_export_jobs_status_idx")
  @@index([createdAt], map: "admin_export_jobs_createdAt_idx")
  @@index([requestedBy], map: "admin_export_jobs_requestedBy_idx")
  @@map("admin_export_jobs")
}

model EpubImportJobRecord {
  id          String   @id
  projectId   String
  requestedBy String
  status      String
  summary     Json
  resultPath  String?
  error       String?
  createdAt   DateTime @default(now())
  startedAt   DateTime?
  finishedAt  DateTime?
  expiresAt   DateTime?
  updatedAt   DateTime @updatedAt

  @@index([status], map: "epub_import_jobs_status_idx")
  @@index([createdAt], map: "epub_import_jobs_createdAt_idx")
  @@index([requestedBy], map: "epub_import_jobs_requestedBy_idx")
  @@index([projectId], map: "epub_import_jobs_projectId_idx")
  @@map("epub_import_jobs")
}

model SecretRotationRecord {
  id           String   @id
  secretFamily String
  keyId        String
  rotatedAt    DateTime
  rotatedBy    String
  notes        String?
  status       String
  createdAt    DateTime @default(now())

  @@index([secretFamily, rotatedAt], map: "secret_rotations_family_rotatedAt_idx")
  @@map("secret_rotations")
}

model UserPreferenceRecord {
  userId    String   @id
  data      Json
  updatedAt DateTime @updatedAt

  @@map("user_preferences")
}

model NormalizedRuntimeStateRecord {
  domain          String   @id
  status          String
  rowCount        Int?
  quarantineCount Int      @default(0)
  checksum        String?
  data            Json?
  updatedAt       DateTime @updatedAt

  @@index([status], map: "normalized_runtime_state_status_idx")
  @@map("normalized_runtime_state")
}

model UserV2Record {
  id             String                   @id
  position       Int                      @default(0)
  name           String
  phrase         String
  bio            String
  avatarUrl      String?
  avatarDisplayX Float                    @default(0.5)
  avatarDisplayY Float                    @default(0.5)
  avatarZoom     Float                    @default(1)
  avatarRotation Float                    @default(0)
  status         String
  accessRole     String?
  createdAt      DateTime
  updatedAt      DateTime
  socials        UserSocialLinkRecord[]
  roles          UserRoleRecord[]
  permissions    UserPermissionRecord[]
  favoriteWorks  UserFavoriteWorkRecord[]

  @@index([position], map: "users_v2_position_idx")
  @@index([accessRole], map: "users_v2_accessRole_idx")
  @@index([status], map: "users_v2_status_idx")
  @@map("users_v2")
}

model UserSocialLinkRecord {
  id       String       @id
  userId   String
  position Int          @default(0)
  label    String
  href     String
  user     UserV2Record @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, position], map: "user_social_links_userId_position_idx")
  @@map("user_social_links")
}

model UserRoleRecord {
  id       String       @id
  userId   String
  position Int          @default(0)
  role     String
  user     UserV2Record @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, position], map: "user_roles_userId_position_idx")
  @@map("user_roles")
}

model UserPermissionRecord {
  id         String       @id
  userId     String
  position   Int          @default(0)
  permission String
  user       UserV2Record @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, position], map: "user_permissions_userId_position_idx")
  @@map("user_permissions")
}

model UserFavoriteWorkRecord {
  id       String       @id
  userId   String
  category String
  position Int          @default(0)
  title    String
  user     UserV2Record @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, category, position], map: "user_favorite_works_userId_category_position_idx")
  @@map("user_favorite_works")
}

model UploadV2Record {
  id              String   @id
  position        Int      @default(0)
  url             String   @unique
  fileName        String
  folder          String
  area            String
  mime            String
  size            Int?
  width           Int?
  height          Int?
  hashSha256      String?
  altText         String
  focalCrops      Json?
  focalPoints     Json?
  focalPoint      Json?
  variants        Json?
  variantsVersion Int      @default(1)
  variantBytes    Int      @default(0)
  createdAt       DateTime
  updatedAt       DateTime

  @@index([position], map: "uploads_v2_position_idx")
  @@index([folder, createdAt], map: "uploads_v2_folder_createdAt_idx")
  @@index([area], map: "uploads_v2_area_idx")
  @@map("uploads_v2")
}

model ProjectV2Record {
  id            String                 @id
  position      Int                    @default(0)
  anilistId     Int?
  title         String
  titleOriginal String
  titleEnglish  String
  synopsis      String
  description   String
  type          String
  status        String
  year          String
  studio        String
  episodes      String
  tags          String[]
  genres        String[]
  cover         String
  coverAlt      String
  banner        String
  bannerAlt     String
  season        String
  schedule      String
  rating        String
  country       String
  source        String
  discordRoleId String
  producers     String[]
  score         Float?
  startDate     String
  endDate       String
  trailerUrl    String
  forceHero     Boolean                @default(false)
  heroImageUrl  String
  heroImageAlt  String
  staff         Json?
  animeStaff    Json?
  views         Int                    @default(0)
  viewsDaily    Json?
  commentsCount Int                    @default(0)
  order         Int                    @default(0)
  deletedAt     DateTime?
  deletedBy     String?
  createdAt     DateTime
  updatedAt     DateTime
  searchText    String
  posts         PostV2Record[]
  relations     ProjectRelationRecord[]
  volumeEntries ProjectVolumeEntryRecord[]
  episodesList  ProjectEpisodeRecord[]
  updates       UpdateV2Record[]
  comments      CommentV2Record[]      @relation("CommentProjectTarget")

  @@index([position], map: "projects_v2_position_idx")
  @@index([deletedAt, updatedAt], map: "projects_v2_deletedAt_updatedAt_idx")
  @@map("projects_v2")
}

model ProjectRelationRecord {
  id         String          @id
  projectId  String
  position   Int             @default(0)
  relation   String
  title      String
  format     String
  status     String
  image      String
  relatedId  String?
  anilistId  String?
  project    ProjectV2Record @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId, position], map: "project_relations_projectId_position_idx")
  @@map("project_relations")
}

model ProjectVolumeEntryRecord {
  id            String          @id
  projectId     String
  volume        Int
  position      Int             @default(0)
  synopsis      String
  coverImageUrl String
  coverImageAlt String
  project       ProjectV2Record @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, volume], map: "project_volume_entries_projectId_volume_key")
  @@index([projectId, position], map: "project_volume_entries_projectId_position_idx")
  @@map("project_volume_entries")
}

model ProjectEpisodeRecord {
  id                String                     @id
  projectId         String
  position          Int                        @default(0)
  number            Int
  volume            Int?
  title             String
  entryKind         String
  entrySubtype      String?
  readingOrder      Int?
  displayLabel      String?
  releaseDate       String
  duration          String
  coverImageUrl     String?
  coverImageAlt     String
  content           String
  contentFormat     String
  publicationStatus String
  hash              String?
  sizeBytes         Int?
  chapterUpdatedAt  String
  project           ProjectV2Record           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sources           ProjectEpisodeSourceRecord[]
  comments          CommentV2Record[]         @relation("CommentEpisodeTarget")

  @@index([projectId, position], map: "project_episodes_projectId_position_idx")
  @@index([projectId, number, volume], map: "project_episodes_projectId_number_volume_idx")
  @@map("project_episodes")
}

model ProjectEpisodeSourceRecord {
  id        String               @id
  episodeId String
  position  Int                  @default(0)
  label     String
  url       String
  episode   ProjectEpisodeRecord @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([episodeId, position], map: "project_episode_sources_episodeId_position_idx")
  @@map("project_episode_sources")
}

model PostV2Record {
  id            String             @id
  position      Int                @default(0)
  title         String
  slug          String             @unique
  coverImageUrl String?
  coverAlt      String
  excerpt       String
  content       String
  contentFormat String
  author        String
  publishedAt   DateTime?
  scheduledAt   DateTime?
  status        String
  seoTitle      String
  seoDescription String
  projectId     String?
  tags          String[]
  views         Int                @default(0)
  viewsDaily    Json?
  commentsCount Int                @default(0)
  deletedAt     DateTime?
  deletedBy     String?
  createdAt     DateTime
  updatedAt     DateTime
  searchText    String
  project       ProjectV2Record?   @relation(fields: [projectId], references: [id], onDelete: SetNull)
  versions      PostVersionV2Record[]
  comments      CommentV2Record[]  @relation("CommentPostTarget")

  @@index([position], map: "posts_v2_position_idx")
  @@index([status, publishedAt], map: "posts_v2_status_publishedAt_idx")
  @@index([projectId], map: "posts_v2_projectId_idx")
  @@index([deletedAt], map: "posts_v2_deletedAt_idx")
  @@map("posts_v2")
}

model PostVersionV2Record {
  id            String       @id
  postId        String
  position      Int          @default(0)
  versionNumber Int
  reason        String
  label         String?
  actorId       String?
  actorName     String?
  slug          String
  createdAt     DateTime
  snapshot      Json
  post          PostV2Record @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([postId, versionNumber], map: "post_versions_v2_postId_versionNumber_key")
  @@index([position], map: "post_versions_v2_position_idx")
  @@index([postId, createdAt], map: "post_versions_v2_postId_createdAt_idx")
  @@map("post_versions_v2")
}

model UpdateV2Record {
  id            String          @id
  position      Int             @default(0)
  projectId     String
  projectTitle  String
  episodeNumber String
  kind          String
  reason        String
  unit          String
  image         String
  updatedAt     DateTime?
  project       ProjectV2Record @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([position], map: "updates_v2_position_idx")
  @@index([projectId, updatedAt], map: "updates_v2_projectId_updatedAt_idx")
  @@map("updates_v2")
}

model CommentV2Record {
  id          String             @id
  position    Int                @default(0)
  status      String
  targetType  String
  postId      String?
  projectId   String?
  episodeId   String?
  parentId    String?
  name        String
  emailHash   String
  content     String
  avatarUrl   String
  approvedAt  DateTime?
  createdAt   DateTime?
  targetMeta  Json?
  updatedAt   DateTime
  post        PostV2Record?      @relation("CommentPostTarget", fields: [postId], references: [id], onDelete: Cascade)
  project     ProjectV2Record?   @relation("CommentProjectTarget", fields: [projectId], references: [id], onDelete: Cascade)
  episode     ProjectEpisodeRecord? @relation("CommentEpisodeTarget", fields: [episodeId], references: [id], onDelete: Cascade)

  @@index([position], map: "comments_v2_position_idx")
  @@index([status, createdAt], map: "comments_v2_status_createdAt_idx")
  @@index([postId], map: "comments_v2_postId_idx")
  @@index([projectId], map: "comments_v2_projectId_idx")
  @@index([episodeId], map: "comments_v2_episodeId_idx")
  @@map("comments_v2")
}
