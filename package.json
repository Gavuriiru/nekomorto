  "name": "vite_react_shadcn_ts",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "engines": {
    "node": "24.14.x",
    "npm": "11.x"
  },
  "scripts": {
    "postinstall": "node scripts/patch-vercel-og.mjs && node scripts/patch-lodash-subpaths.mjs",
    "predev": "npm run prisma:prepare",
    "setup:dev": "node scripts/setup-dev.mjs",
    "dev": "node scripts/dev-watch-runner.mjs",
    "predev:server": "npm run prisma:prepare",
    "dev:server": "node scripts/dev-watch-runner.mjs",
    "dev:client": "vite --port 5173",
    "dev:client:local-api": "cross-env VITE_API_BASE=http://127.0.0.1:8080 vite --port 5173",
    "build": "vite build && npm run build:pwa && node scripts/check-build-chunks.mjs && npm run build:home:guard",
    "build:audit": "cross-env VITE_BUILD_SOURCEMAP=true vite build && npm run build:pwa && node scripts/check-build-chunks.mjs",
    "build:home:guard": "node scripts/check-home-build.mjs",
    "build:dev": "vite build --mode development && npm run build:pwa",
    "build:pwa": "node scripts/build-pwa.mjs",
    "start": "cross-env NODE_ENV=production node server/index.js",
    "prisma:generate": "prisma generate",
    "prisma:prepare": "npm run prisma:generate && npm run prisma:migrate:deploy",
    "prisma:migrate:deploy": "node scripts/prisma-migrate-deploy.mjs",
    "db:backup": "node --env-file=.env scripts/backup-data.mjs",
    "db:backfill:normalized": "node --env-file=.env scripts/backfill-normalized-runtime.mjs",
    "projects:backfill:anilist": "node --env-file=.env scripts/backfill-project-anilist-metadata.mjs",
    "api:smoke": "node scripts/smoke-api.mjs",
    "api:health:check": "node scripts/check-health.mjs",
    "staging:parity:check": "node scripts/check-staging-parity.mjs",
    "reports:outdated": "node scripts/save-outdated-report.mjs",
    "lighthouse:home:mobile": "node scripts/lighthouse-home-mobile.mjs --runs=3 --strict",
    "lighthouse:home:mobile:ci": "npm run build && node scripts/lighthouse-home-mobile.mjs --runs=3 --strict --start-preview",
    "lighthouse:projects:mobile": "node scripts/lighthouse-projects.mjs --profile=mobile --runs=3 --strict",
    "lighthouse:projects:desktop": "node scripts/lighthouse-projects.mjs --profile=desktop --runs=3 --strict",
    "lighthouse:dashboard:desktop": "node scripts/lighthouse-dashboard-desktop.mjs --runs=3 --strict",
    "lighthouse:reader-pages:mobile": "node scripts/lighthouse-reader-pages.mjs --runs=3 --strict",
    "lighthouse:reader-pages:mobile:ci": "npm run build:audit && node scripts/lighthouse-reader-pages.mjs --runs=3 --strict --start-preview",
    "lighthouse:public-surface": "node scripts/lighthouse-public-surface.mjs --runs=3",
    "lighthouse:public-surface:ci": "npm run build:audit && node scripts/lighthouse-public-surface.mjs --runs=3 --start-preview",
    "lighthouse:public-surface:compare": "node scripts/compare-public-surface-baseline.mjs",
    "lighthouse:public-surface:accept": "node scripts/accept-public-surface-baseline.mjs",
    "lint": "biome check . --formatter-enabled=false --assist-enabled=false",
    "format": "biome format --write .",
    "format:check": "biome check . --formatter-enabled=true --linter-enabled=false --assist-enabled=false",
    "preview": "vite preview",
    "uploads:reorganize": "node --env-file=.env scripts/reorganize-upload-folders.mjs",
    "uploads:check-integrity": "node --env-file=.env scripts/check-upload-integrity.mjs",
    "uploads:sync-to-object-storage": "node --env-file=.env scripts/sync-uploads-to-object-storage.mjs",
    "uploads:restore-from-object-storage": "node --env-file=.env scripts/restore-uploads-from-object-storage.mjs",
    "uploads:generate-inventory": "node --env-file=.env scripts/generate-uploads-inventory.mjs",
    "uploads:localize-project-images": "node --env-file=.env scripts/localize-project-images.mjs",
    "uploads:isolate-project-images": "node --env-file=.env scripts/isolate-project-images.mjs",
    "uploads:backfill-project-variant-profiles": "node --env-file=.env scripts/backfill-project-upload-variant-profiles.mjs",
    "uploads:backfill-media": "node --env-file=.env scripts/backfill-upload-media.mjs",
    "uploads:backfill-variants-avif-only": "node --env-file=.env scripts/backfill-upload-variants-avif-only.mjs",
    "users:migrate-permissions-v2": "node --env-file=.env scripts/migrate-permissions-v2.mjs",
    "typecheck": "tsc -b --pretty false",
    "typecheck:ts7-preview": "npm exec --package=@typescript/native-preview@7.0.0-dev.20260401.1 -- tsgo -b --pretty false",
    "test": "vitest run",
    "test:a11y": "vitest run --config vitest.a11y.config.ts",
    "test:watch": "vitest"
  },
