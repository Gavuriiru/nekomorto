{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "files": {
    "includes": [
      "**",
      "!**/.codex-test-hidden/**",
      "!**/.lighthouse/**",
      "!**/backups/**",
      "!**/dev-dist/**",
      "!**/dist/**",
      "!**/node_modules/**",
      "!**/output/**",
      "!**/public/uploads/**",
      "!**/reports/**",
      "!**/server/data/**",
      "!**/src/lexical-playground/**",
      "!**/tmp/**",
      "!**/package-lock.json",
      "!**/tsconfig*.json"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": false,
      "correctness": {
        "noUnusedVariables": "warn"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "jsxQuoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
